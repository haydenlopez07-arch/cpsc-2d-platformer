{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "commonjs",
    "sourceMap": true,
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "./build",
    "rootDir": "./src"
  },
  "include": ["src/**/*", "*.d.ts"]
}
//TypeScript → (ts-loader) → webpack → dist/bundle.js
